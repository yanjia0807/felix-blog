{
  "expo": {
    "name": "felix-blog",
    "slug": "felix-blog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "felix-blog",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "info.yanjia.felix-blog",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "$(PRODUCT_NAME) 需要您的位置信息来提供个性化体验。",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "$(PRODUCT_NAME) 需要持续访问您的位置信息来提供后台服务。",
        "NSLocationAlwaysUsageDescription": "$(PRODUCT_NAME) 需要始终访问您的位置信息以实现完整功能。"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "info.yanjia.felixblog"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "应用需要访问您的照片，以便与您的朋友分享照片。"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "允许 $(PRODUCT_NAME) 访问您的相机",
          "microphonePermission": "允许 $(PRODUCT_NAME) 访问您的麦克风",
          "recordAudioAndroid": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
